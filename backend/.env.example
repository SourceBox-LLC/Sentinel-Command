# Backend Environment Variables

# Clerk Authentication (required)
# Get these from https://clerk.com/ dashboard
CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_secret_key_here
CLERK_WEBHOOK_SECRET=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=sqlite:///./sentinel.db

# In-memory HLS segment cache (live streaming)
# Max segments cached per camera (older ones evicted automatically)
# With 1s segments from CameraNode, 60 = ~60 second window
SEGMENT_CACHE_MAX_PER_CAMERA=60
# Max bytes accepted for a single pushed segment
SEGMENT_PUSH_MAX_BYTES=2097152
# Run cache eviction every N playlist updates
CLEANUP_INTERVAL=20
# Free segment cache for cameras that have been offline this long
INACTIVE_CAMERA_CLEANUP_HOURS=24

# Log retention (stream, MCP, and audit logs — days)
LOG_RETENTION_DAYS=90

# ── Email notifications (Resend) ─────────────────────────────────────
# EMAIL_ENABLED is the global kill-switch — leave false in local dev so
# the worker logs "would have sent" instead of burning the Resend quota.
EMAIL_ENABLED=false
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
# From MUST be on a Resend-verified sending domain. sentinel-command.com
# is verified (DKIM + SPF/Return-Path). No-reply by design — customers
# email support@sentinel-command.com directly, not by replying to alerts.
EMAIL_FROM_ADDRESS=notifications@sentinel-command.com
EMAIL_FROM_NAME=Sentinel by SourceBox
